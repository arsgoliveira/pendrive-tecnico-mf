<html>
<head>
<title>MicroFast Técnico v3</title>
<HTA:APPLICATION ID="MFTecnico"
  APPLICATIONNAME="MicroFast Técnico v3"
  BORDER="normal" BORDERSTYLE="complex"
  CAPTION="yes" SHOWINTASKBAR="yes"
  SINGLEINSTANCE="yes" WINDOWSTATE="maximize"
  SCROLL="no" ICON="config\logo.ico"/>
<meta http-equiv="X-UA-Compatible" content="IE=10">
<meta charset="UTF-8">
<style>
@import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@400;600;700&family=Exo+2:wght@300;400;600;700&display=swap');

/* RESET */
* { margin:0; padding:0; -ms-box-sizing:border-box; box-sizing:border-box; }
html { zoom:1.3; }
html, body { width:100%; height:100%; }
body { background:#0d1117; color:#e0f0ff; font-family:'Exo 2',Segoe UI,Arial,sans-serif; font-size:15px; overflow:hidden; }

/* AUTH OVERLAY — cobre TUDO */
#authOv {
  position:fixed;
  top:0; left:0; right:0; bottom:0;
  width:100%; height:100%;
  background:#000000;
  z-index:9000;
  display:-ms-flexbox; display:flex;
  -ms-flex-align:center; align-items:center;
  -ms-flex-pack:center; justify-content:center;
}
.abox {
  background:#111820;
  border:1px solid #2a4a6e;
  border-radius:14px;
  padding:2.5rem;
  width:480px;
  max-width:95%;
}
.alogo { text-align:center; margin-bottom:1.5rem; }
.aic {
  width:64px; height:64px;
  background:#0097a7;
  border-radius:10px;
  display:inline-block;
  line-height:64px;
  text-align:center;
  font-family:'Rajdhani',Arial,sans-serif;
  font-weight:700; font-size:28px; color:#000;
  margin-bottom:10px;
}
.atit { font-family:'Rajdhani',Arial,sans-serif; font-size:26px; font-weight:700; color:#e0f0ff; }
.asub { font-size:15px; color:#4a7a9b; margin-top:3px; }
.atabs { display:-ms-flexbox; display:flex; margin-bottom:1.25rem; border:1px solid #2a4a6e; border-radius:5px; overflow:hidden; }
.atab { -ms-flex:1; flex:1; padding:10px; text-align:center; font-size:15px; color:#4a7a9b; cursor:pointer; background:none; border:none; font-family:'Exo 2',Arial,sans-serif; }
.atab.on { background:#0097a7; color:#fff; font-weight:700; }
.afield { margin-bottom:1rem; }
.afield label { display:block; font-size:13px; color:#4a7a9b; letter-spacing:1px; text-transform:uppercase; margin-bottom:6px; }
.afield input {
  width:100%; background:#1a2332; border:1px solid #2a4a6e;
  border-radius:5px; padding:11px 14px; color:#e0f0ff;
  font-family:'Share Tech Mono',Consolas,monospace; font-size:16px; outline:none;
}
.abtn {
  width:100%; padding:14px;
  background:#0097a7; color:#000;
  font-family:'Rajdhani',Arial,sans-serif;
  font-size:18px; font-weight:700; letter-spacing:2px;
  border:none; border-radius:5px; cursor:pointer;
  margin-top:5px;
}
.amsg { font-size:15px; color:#ff1744; text-align:center; margin-top:7px; min-height:20px; }
.anote { font-size:14px; color:#4a7a9b; text-align:center; margin-top:8px; }

/* HEADER */
#hdr {
  background:#111820;
  border-bottom:1px solid #2a4a6e;
  padding:0 1.5rem;
  height:64px;
  display:-ms-flexbox; display:flex;
  -ms-flex-align:center; align-items:center;
  -ms-flex-pack:justify; justify-content:space-between;
  position:relative; z-index:100;
}
.hlogo { display:-ms-flexbox; display:flex; -ms-flex-align:center; align-items:center; }
.hic {
  width:40px; height:40px; background:#0097a7;
  border-radius:7px; display:inline-block;
  line-height:40px; text-align:center;
  font-family:'Rajdhani',Arial,sans-serif;
  font-weight:700; font-size:18px; color:#000;
  margin-right:12px;
}
.htxt { font-family:'Rajdhani',Arial,sans-serif; font-size:22px; font-weight:700; }
.htxt span { color:#00e5ff; }
.hsub { font-size:12px; color:#4a7a9b; letter-spacing:2px; text-transform:uppercase; }
.hright { display:-ms-flexbox; display:flex; -ms-flex-align:center; align-items:center; }
.hclk { font-family:'Share Tech Mono',Consolas,monospace; font-size:16px; color:#00e5ff; margin-right:1rem; }
.hmode { font-size:13px; padding:4px 12px; border-radius:10px; font-weight:700; margin-right:.875rem; }
.hmode.online  { background:rgba(0,200,83,.15); color:#00c853; border:1px solid rgba(0,200,83,.3); }
.hmode.offline { background:rgba(255,171,0,.15); color:#ffab00; border:1px solid rgba(255,171,0,.3); }
.hbadge { background:#1a2332; border:1px solid #2a4a6e; border-radius:20px; padding:4px 14px; font-size:14px; color:#8ab4d4; margin-right:.875rem; }
.hbtn { background:transparent; border:1px solid #2a4a6e; border-radius:20px; padding:6px 16px; font-size:14px; color:#4a7a9b; cursor:pointer; font-family:'Exo 2',Arial,sans-serif; }

/* LAYOUT */
#lay { display:-ms-flexbox; display:flex; height:calc(100vh - 64px); overflow:hidden; }

/* SIDEBAR */
#sb { width:240px; min-width:240px; background:#111820; border-right:1px solid #1e3048; overflow-y:auto; padding:.75rem 0; }
.ns { padding:.5rem 1.1rem .2rem; font-size:12px; letter-spacing:2px; color:#4a7a9b; text-transform:uppercase; }
.ni { display:-ms-flexbox; display:flex; -ms-flex-align:center; align-items:center; padding:10px 1.2rem; cursor:pointer; color:#8ab4d4; font-size:15px; border-left:3px solid transparent; }
.ni:hover { background:rgba(0,229,255,.04); color:#e0f0ff; }
.ni.on { background:rgba(0,229,255,.08); color:#00e5ff; border-left-color:#00e5ff; font-weight:700; }
.nic { font-size:17px; width:20px; text-align:center; margin-right:10px; display:inline-block; }
.nbg { margin-left:auto; background:#0097a7; color:#fff; font-size:11px; padding:2px 8px; border-radius:10px; }

/* CONTENT */
#cnt { -ms-flex:1; flex:1; padding:1.25rem; overflow-y:auto; }
.pg { display:none; }
.pg.on { display:block; }

/* PAGE TITLES */
.ptit { font-family:'Rajdhani',Arial,sans-serif; font-size:28px; font-weight:700; letter-spacing:1px; margin-bottom:5px; color:#e0f0ff; }
.ptit span { color:#00e5ff; }
.pdesc { font-size:15px; color:#4a7a9b; margin-bottom:1rem; }

/* FLEX GRID — compatível com IE */
.row { display:-ms-flexbox; display:flex; margin:-5px; }
.col { -ms-flex:1; flex:1; padding:5px; min-width:0; }
.col2 { -ms-flex:0 0 50%; flex:0 0 50%; padding:5px; min-width:0; }
.col3 { -ms-flex:0 0 33.33%; flex:0 0 33.33%; padding:5px; min-width:0; }
.col4 { -ms-flex:0 0 25%; flex:0 0 25%; padding:5px; min-width:0; }
.row-wrap { -ms-flex-wrap:wrap; flex-wrap:wrap; }
.mb8 { margin-bottom:8px; }
.mb14 { margin-bottom:14px; }

/* CARD */
.card { background:#131920; border:1px solid #1e3048; border-radius:8px; padding:1rem; }
.ct { font-family:'Rajdhani',Arial,sans-serif; font-size:15px; font-weight:700; color:#8ab4d4; letter-spacing:1px; text-transform:uppercase; margin-bottom:.7rem; }

/* TOOL BUTTON */
.tb { display:-ms-flexbox; display:flex; -ms-flex-align:flex-start; align-items:flex-start; background:#131920; border:1px solid #1e3048; border-radius:8px; padding:.85rem 1rem; cursor:pointer; text-align:left; width:100%; color:#e0f0ff; font-family:'Exo 2',Arial,sans-serif; margin-bottom:8px; }
.tb:hover { border-color:#00bcd4; background:rgba(0,188,212,.05); }
.tik { width:40px; height:40px; border-radius:6px; display:inline-block; text-align:center; line-height:40px; font-size:19px; margin-right:12px; -ms-flex-negative:0; flex-shrink:0; }
.tinfo { -ms-flex:1; flex:1; }
.tn { font-size:16px; font-weight:700; color:#e0f0ff; margin-bottom:3px; }
.td { font-size:14px; color:#4a7a9b; line-height:1.5; }
.tbg { font-size:11px; padding:3px 9px; border-radius:10px; font-weight:700; margin-top:5px; display:inline-block; }
.bc { background:rgba(0,229,255,.1); color:#00e5ff; border:1px solid rgba(0,229,255,.2); }
.bg { background:rgba(0,255,136,.1); color:#00c853; border:1px solid rgba(0,255,136,.2); }
.ba { background:rgba(255,171,0,.1); color:#ffab00; border:1px solid rgba(255,171,0,.2); }
.br { background:rgba(255,23,68,.1); color:#ff1744; border:1px solid rgba(255,23,68,.2); }
.bpu{ background:rgba(156,39,176,.1); color:#9c27b0; border:1px solid rgba(156,39,176,.2); }

/* TERMINAL */
.term { background:#060c12; border:1px solid #2a4a6e; border-radius:6px; padding:.85rem; font-family:'Share Tech Mono',Consolas,monospace; font-size:14px; line-height:1.8; height:200px; overflow-y:auto; margin-top:.85rem; }
.tl { margin-bottom:1px; }
.tcp { color:#0097a7; }
.tok { color:#00ff88; }
.tw  { color:#ffab00; }
.te  { color:#ff1744; }
.ti  { color:#8ab4d4; }
.tdm { color:#4a7a9b; }

/* FORM */
.fl { display:block; font-size:13px; color:#4a7a9b; letter-spacing:1px; text-transform:uppercase; margin-bottom:6px; }
.fi { width:100%; background:#1a2332; border:1px solid #2a4a6e; border-radius:5px; padding:10px 12px; color:#e0f0ff; font-family:'Share Tech Mono',Consolas,monospace; font-size:15px; outline:none; margin-bottom:.75rem; }
.fi:focus { border-color:#00e5ff; }

/* BUTTONS */
.btn { padding:10px 18px; border-radius:5px; font-family:'Rajdhani',Arial,sans-serif; font-size:16px; font-weight:700; letter-spacing:1px; border:none; cursor:pointer; margin-right:8px; margin-bottom:8px; display:inline-block; }
.bp { background:#0097a7; color:#000; }
.bp:hover { background:#00bcd4; }
.bo { background:transparent; color:#00e5ff; border:1px solid #00bcd4; }
.bo:hover { background:rgba(0,229,255,.08); }
.bd { background:#ff1744; color:#fff; }

/* STATS */
.stat { background:#131920; border:1px solid #1e3048; border-radius:8px; padding:.85rem 1rem; }
.sl { font-size:13px; color:#4a7a9b; text-transform:uppercase; letter-spacing:1px; margin-bottom:4px; }
.sv { font-family:'Share Tech Mono',Consolas,monospace; font-size:28px; color:#00e5ff; }

/* STATUS BAR */
.sbar { display:-ms-flexbox; display:flex; -ms-flex-align:center; align-items:center; padding:8px 12px; background:#1a2332; border:1px solid #1e3048; border-radius:5px; margin-bottom:.85rem; font-family:'Share Tech Mono',Consolas,monospace; font-size:14px; color:#4a7a9b; }
.dot { width:7px; height:7px; border-radius:50%; -ms-flex-negative:0; flex-shrink:0; margin-right:7px; display:inline-block; }
.dg { background:#00ff88; }
.da { background:#ffab00; }
.dr { background:#ff1744; }

/* PROGRESS */
.pw { background:#1a2332; border-radius:4px; height:5px; overflow:hidden; margin:4px 0; }
.pb { height:100%; border-radius:4px; background:#0097a7; -webkit-transition:width .4s; transition:width .4s; }

/* TABLE */
.tbl { width:100%; border-collapse:collapse; font-size:15px; }
.tbl th { text-align:left; padding:8px 12px; font-size:13px; color:#4a7a9b; letter-spacing:1px; text-transform:uppercase; border-bottom:1px solid #2a4a6e; font-weight:500; }
.tbl td { padding:9px 12px; border-bottom:1px solid #1e3048; color:#8ab4d4; }
.tbl tr:hover td { background:rgba(0,229,255,.03); color:#e0f0ff; }
.mono { font-family:'Share Tech Mono',Consolas,monospace; font-size:14px; }

/* SECTION TITLE */
.stit { font-family:'Rajdhani',Arial,sans-serif; font-size:19px; font-weight:700; color:#e0f0ff; margin:1rem 0 .7rem; border-bottom:1px solid #1e3048; padding-bottom:6px; }

/* LOCK */
.alock { display:-ms-flexbox; display:flex; -ms-flex-align:center; align-items:center; font-size:15px; color:#ffab00; background:rgba(255,171,0,.07); border:1px solid rgba(255,171,0,.2); border-radius:5px; padding:8px 12px; margin-bottom:10px; }

/* GUIDE STEPS */
.gstep { background:#131920; border:1px solid #1e3048; border-radius:7px; padding:.85rem 1rem; margin-bottom:.6rem; }
.gsn { display:inline-block; width:28px; height:28px; border-radius:50%; background:#0097a7; color:#000; font-size:14px; font-weight:700; text-align:center; line-height:28px; margin-right:10px; }
.gst { font-size:17px; font-weight:700; color:#e0f0ff; }
.gsd { font-size:15px; color:#8ab4d4; margin-top:5px; margin-left:38px; line-height:1.7; }
.gsc { font-family:'Share Tech Mono',Consolas,monospace; font-size:14px; color:#00e5ff; background:rgba(0,229,255,.06); border:1px solid rgba(0,229,255,.15); border-radius:4px; padding:6px 10px; margin-top:6px; margin-left:38px; display:block; }

/* REPORT VIEWER */
.rv { background:#060c12; border:1px solid #2a4a6e; border-radius:6px; padding:1rem; font-family:'Share Tech Mono',Consolas,monospace; font-size:14px; line-height:1.8; height:350px; overflow-y:auto; color:#8ab4d4; }

/* GITHUB BADGE */
.ghbadge { display:-ms-flexbox; display:flex; -ms-flex-align:center; align-items:center; background:rgba(0,229,255,.04); border:1px solid rgba(0,229,255,.15); border-radius:7px; padding:10px 14px; font-size:15px; color:#8ab4d4; margin-bottom:.85rem; }
.ghbadge a { color:#00e5ff; text-decoration:none; }

/* TOAST */
#toasts { position:fixed; bottom:1.25rem; right:1.25rem; z-index:9500; }
.toast { background:#1a2332; border:1px solid #2a4a6e; border-radius:7px; padding:10px 16px; font-size:15px; color:#e0f0ff; margin-bottom:6px; display:-ms-flexbox; display:flex; -ms-flex-align:center; align-items:center; max-width:360px; }
.toast.ok  { border-color:rgba(0,200,83,.4); background:rgba(0,200,83,.07); }
.toast.er  { border-color:rgba(255,23,68,.4); background:rgba(255,23,68,.07); }
.toast.inf { border-color:rgba(0,229,255,.3); background:rgba(0,229,255,.05); }

/* SCROLLBAR */
::-webkit-scrollbar { width:6px; }
::-webkit-scrollbar-track { background:#0d1117; }
::-webkit-scrollbar-thumb { background:#2a4a6e; border-radius:4px; }
</style>
</head>
<body>

<!-- AUTH OVERLAY -->
<div id="authOv">
  <div class="abox">
    <div class="alogo">
      <div class="aic">MF</div>
      <div class="atit">MicroFast Técnico v3</div>
      <div class="asub">Pendrive de Manutenção Profissional · Santos/SP</div>
    </div>
    <div class="atabs">
      <button class="atab on" id="tabP" onclick="setTab('P')">🔧 Técnico</button>
      <button class="atab"    id="tabC" onclick="setTab('C')">🏢 SGS Corporativo</button>
    </div>
    <div id="frmP">
      <div class="afield">
        <label>Senha Técnico</label>
        <input type="password" id="tpwd" autocomplete="off" onkeydown="if(event.keyCode==13)doAuth()"/>
      </div>
    </div>
    <div id="frmC" style="display:none">
      <div class="afield">
        <label>E-mail ADM</label>
        <input type="text" value="antonio.oliveira.adm@sgs.com" readonly style="color:#4a7a9b"/>
      </div>
      <div class="afield">
        <label>Senha Corporativa SGS</label>
        <input type="password" id="cpwd" autocomplete="off" onkeydown="if(event.keyCode==13)doAuth()"/>
      </div>
    </div>
    <button class="abtn" onclick="doAuth()">ACESSAR PAINEL</button>
    <div class="amsg" id="amsg"></div>
    <div class="anote" id="anote">Primeiro acesso: defina sua senha (mínimo 6 caracteres)</div>
    <div style="text-align:center;font-size:14px;color:#4a7a9b;margin-top:8px" id="amode">Verificando ambiente...</div>
  </div>
</div>

<!-- HEADER -->
<div id="hdr">
  <div class="hlogo">
    <div class="hic">MF</div>
    <div>
      <div class="htxt">MICRO<span>FAST</span></div>
      <div class="hsub">Pendrive Técnico v3.0</div>
    </div>
  </div>
  <div class="hright">
    <div class="hmode offline" id="hmode">OFFLINE</div>
    <div class="hbadge" id="hbadge">TÉCNICO</div>
    <div class="hclk" id="clk">--:--:--</div>
    <button class="hbtn" onclick="logout()">sair ✕</button>
  </div>
</div>

<!-- LAYOUT -->
<div id="lay">

<!-- SIDEBAR -->
<div id="sb">
  <div class="ns">Principal</div>
  <div class="ni on" onclick="pg('dash')"><span class="nic">⚡</span>Dashboard</div>
  <div class="ni" onclick="pg('diag')"><span class="nic">🔍</span>Diagnóstico</div>
  <div class="ni" onclick="pg('clean')"><span class="nic">🧹</span>Limpeza</div>
  <div class="ni" onclick="pg('relat')"><span class="nic">📋</span>Relatórios&nbsp;<span class="nbg" id="nRelat">0</span></div>
  <div class="ni" onclick="pg('hardware')"><span class="nic">🖥️</span>Hardware Live</div>
  <div class="ni" onclick="pg('historico')"><span class="nic">📊</span>Histórico</div>
  <div class="ns">Ferramentas</div>
  <div class="ni" onclick="pg('rede')"><span class="nic">📡</span>Rede</div>
  <div class="ni" onclick="pg('drivers')"><span class="nic">🔧</span>Drivers</div>
  <div class="ni" onclick="pg('progs')"><span class="nic">📦</span>Programas</div>
  <div class="ni" onclick="pg('winupd')"><span class="nic">🪟</span>Win Update</div>
  <div class="ni" onclick="pg('tools')"><span class="nic">🛠️</span>Ferramentas</div>
  <div class="ns">Guias</div>
  <div class="ni" onclick="pg('guias')"><span class="nic">📖</span>Passo a Passo</div>
  <div class="ns">Sistema</div>
  <div class="ni" onclick="pg('admin')"><span class="nic">🔐</span>Admin / SGS</div>
  <div class="ni" onclick="pg('update')"><span class="nic">🔄</span>Atualizar</div>
  <div class="ni" onclick="pg('cfg')"><span class="nic">⚙️</span>Configurações</div>
</div>

<!-- MAIN -->
<div id="cnt">

<!-- DASHBOARD -->
<div class="pg on" id="pg-dash">
  <div class="ptit">Dashboard <span>Técnico</span></div>
  <div class="pdesc">Painel híbrido — HTA (pendrive) e navegador (online)</div>
  <div class="ghbadge">
    <span style="margin-right:4px">🐙</span>
    <span style="margin-right:6px">Repositório:</span>
    <a href="#" onclick="abrirURL('https://github.com/arsgoliveira/pendrive-tecnico-mf');return false;">github.com/arsgoliveira/pendrive-tecnico-mf</a>
    <span style="margin-left:auto;color:#4a7a9b" id="ghVer">v3.0.0</span>
  </div>
  <div class="sbar"><span class="dot dg"></span><span id="dSt">Sistema pronto — todos os módulos carregados</span></div>
  <div style="background:rgba(255,171,0,.08);border:1px solid rgba(255,171,0,.3);border-radius:7px;padding:8px 14px;margin-bottom:.875rem;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;gap:10px;">
    <span style="font-size:16px;flex-shrink:0">🛡️</span>
    <span style="font-size:12px;color:#ffab00;-ms-flex:1;flex:1"><strong>1º uso ou erro de antivírus?</strong> Execute <strong>SETUP-DEFENDER.bat</strong> como Admin para liberar os scripts no Windows Defender.</span>
    <button class="btn ba" style="font-size:11px;padding:5px 12px;white-space:nowrap;flex-shrink:0" onclick="execSetupDefender()">⚙️ Setup</button>
  </div>
  <div class="row mb14">
    <div class="col4"><div class="stat"><div class="sl">Ações sessão</div><div class="sv" id="sCnt">0</div></div></div>
    <div class="col4"><div class="stat"><div class="sl">Diagnósticos</div><div class="sv" id="sDiag">0</div></div></div>
    <div class="col4"><div class="stat"><div class="sl">Modo</div><div class="sv" style="font-size:20px;padding-top:4px" id="sModo">Técnico</div></div></div>
    <div class="col4"><div class="stat"><div class="sl">Ambiente</div><div class="sv" style="font-size:20px;padding-top:4px" id="sEnv">HTA</div></div></div>
  </div>
  <div class="stit">Acesso Rápido</div>
  <div class="row row-wrap">
    <div class="col3"><button class="tb" onclick="pg('diag')"><span class="tik" style="background:rgba(0,229,255,.1)">🔍</span><span class="tinfo"><span class="tn">Diagnóstico Completo</span><br><span class="td">Hardware real + avaliação upgrade + relatório</span><br><span class="tbg bc">Gera TXT</span></span></button></div>
    <div class="col3"><button class="tb" onclick="execLimpeza()"><span class="tik" style="background:rgba(0,255,136,.1)">🧹</span><span class="tinfo"><span class="tn">Limpeza Automática</span><br><span class="td">Temp, Prefetch, Lixeira, WU, DNS</span><br><span class="tbg bg">1 Clique</span></span></button></div>
    <div class="col3"><button class="tb" onclick="pg('rede')"><span class="tik" style="background:rgba(0,188,212,.1)">📡</span><span class="tinfo"><span class="tn">Ferramentas de Rede</span><br><span class="td">Ping, tracert, DNS, port scan</span><br><span class="tbg bc">Completo</span></span></button></div>
    <div class="col3"><button class="tb" onclick="execDrivers('detectar')"><span class="tik" style="background:rgba(0,188,212,.08)">🖥️</span><span class="tinfo"><span class="tn">Detectar Hardware</span><br><span class="td">Modelo real + site do fabricante</span><br><span class="tbg bc">Auto</span></span></button></div>
