<!-- ENGINE (JavaScript puro — compatível com IE=edge) -->
<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script language="JavaScript">

// ── FileSystem / Shell helpers ──────────────────────────
var _fso = null, _shell = null, _sa = null;
function fso()   { if(!_fso)   _fso   = new ActiveXObject('Scripting.FileSystemObject'); return _fso; }
function shell() { if(!_shell) _shell = new ActiveXObject('WScript.Shell'); return _shell; }
function sa()    { if(!_sa)    _sa    = new ActiveXObject('Shell.Application'); return _sa; }

// ── GetBase — detecta pasta raiz do pendrive ────────────
function GetBase() {
    try {
        var p = decodeURIComponent(document.location.pathname);
        p = p.replace(/\//g, '\\');
        while (p.charAt(0) === '\\') p = p.substring(1);
        if (p.indexOf(':') < 0) return 'D:\\Pendrive Tecnico MF';
        var base = p.substring(0, p.lastIndexOf('\\'));
        if (!fso().FolderExists(base)) return 'D:\\Pendrive Tecnico MF';
        return base;
    } catch(e) {
        return 'D:\\Pendrive Tecnico MF';
    }
}

// ── INI read/write ──────────────────────────────────────
function ReadCfg(k) {
    try {
        var cfg = GetBase() + '\\config\\dados.ini';
        if (!fso().FileExists(cfg)) return '';
        var f = fso().OpenTextFile(cfg, 1, false, -1);
        while (!f.AtEndOfStream) {
            var line = f.ReadLine();
            var idx = line.indexOf('=');
            if (idx > 0 && line.substring(0,idx).replace(/^\s+|\s+$/g,'') === k) {
                var val = line.substring(idx+1).replace(/^\s+|\s+$/g,'');
                f.Close(); return val;
            }
        }
        f.Close();
    } catch(e) {}
    return '';
}

function WriteCfg(k, v) {
    try {
        var base = GetBase();
        var cfg = base + '\\config\\dados.ini';
        if (!fso().FolderExists(base+'\\config')) fso().CreateFolder(base+'\\config');
        var tmp = '', found = false;
        if (fso().FileExists(cfg)) {
            var f = fso().OpenTextFile(cfg, 1, false, -1);
            while (!f.AtEndOfStream) {
                var line = f.ReadLine();
                var idx = line.indexOf('=');
                if (idx > 0 && line.substring(0,idx).replace(/^\s+|\s+$/g,'') === k) {
                    tmp += k + '=' + v + '\n'; found = true;
                } else {
                    tmp += line + '\n';
                }
            }
            f.Close();
        }
        if (!found) tmp += k + '=' + v + '\n';
        var out = fso().OpenTextFile(cfg, 2, true, -1);
        out.Write(tmp);
        out.Close();
    } catch(e) {}
}

// ── ReadFile ────────────────────────────────────────────
function ReadFile(fp) {
    try {
        if (!fso().FileExists(fp)) return '';
        var f = fso().OpenTextFile(fp, 1, false, -1);
        var txt = f.ReadAll();
        f.Close();
        return txt;
    } catch(e) { return ''; }
}

// ── ListRelatorios ──────────────────────────────────────
function ListRelatorios() {
    try {
        var base = GetBase();
        var rDir = base + '\\relatorios';
        if (!fso().FolderExists(rDir)) { fso().CreateFolder(rDir); return ''; }
        var folder = fso().GetFolder(rDir);
        var files = new Enumerator(folder.Files);
        var arr = [];
        for (; !files.atEnd(); files.moveNext()) {
            var fi = files.item();
            var nm = fi.Name.toLowerCase();
            if (nm.slice(-4)==='.txt' || nm.slice(-5)==='.html') {
                arr.push(fi.Name + '|' + fi.Path + '|' + fi.DateLastModified);
            }
        }
        arr.sort(function(a,b){ return b.localeCompare(a); });
        return arr.join('\n');
    } catch(e) { return ''; }
}

// ── Sanitiza inputs para evitar quebra de comandos PS ────
function san(s) {
    if (!s) return '';
    // Remove apenas caracteres que quebram o arquivo INI de params
    return String(s).replace(/["\r\n]/g,'').replace(/'/g,'\u2019').substring(0,120);
}

// ── Executar scripts via cmd /k (mantém janela aberta) ─────
function RunPS1Admin(script, args) {
    try {
        var psCmd = 'powershell.exe -NoProfile -ExecutionPolicy Bypass -File "' + script + '"';
        if (args) psCmd += ' ' + args;
        sa().ShellExecute('cmd.exe', '/k ' + psCmd, '', 'runas', 1);
    } catch(e) {
        var msg = e.message || String(e);
        if (msg.indexOf('1260') >= 0 || msg.indexOf('bloqueado') >= 0 || msg.indexOf('blocked') >= 0) {
            alert('ANTIVÍRUS BLOQUEOU O SCRIPT\n\nExecute SETUP-DEFENDER.bat como Admin.');
        } else {
            alert('Erro ao executar:\n' + msg);
        }
    }
}

function RunBatAdmin(script) {
    try {
        sa().ShellExecute('cmd.exe', '/k "' + script + '"', '', 'runas', 1);
    } catch(e) { alert('Erro: ' + e.message); }
}

function RunPS1(script, args) {
    try {
        var psCmd = 'powershell.exe -NoProfile -ExecutionPolicy Bypass -File "' + script + '"';
        if (args) psCmd += ' ' + args;
        sa().ShellExecute('cmd.exe', '/k ' + psCmd, '', '', 1);
    } catch(e) { alert('Erro: ' + e.message); }
}

function OpenDir(d) {
    try { sa().ShellExecute('explorer.exe', '"' + d + '"', '', '', 1); } catch(e) {}
}

function OpenURL(url) {
    try { sa().ShellExecute(url, '', '', '', 1); } catch(e) {}
}

// ── Ações específicas ───────────────────────────────────
function VBS_Diag(cli, ctx, obs, nm) {
    var b = GetBase();
    // Salva parâmetros em arquivo temporário para evitar
    // qualquer problema de quoting/escaping no ShellExecute
    var paramFile = b + '\\config\\diag_params.ini';
    var outPath   = b + '\\relatorios';
    try {
        var content = 'ClienteNome=' + san(cli) + '\n' +
                      'Contexto='    + san(ctx) + '\n' +
                      'Observacoes=' + san(obs) + '\n' +
                      'TecnicoNome=' + san(nm)  + '\n' +
                      'OutputPath='  + outPath  + '\n';
        var f = fso().OpenTextFile(paramFile, 2, true, -1);
        f.Write(content);
        f.Close();
    } catch(e) {}
    // Passa apenas o arquivo de params — sem aspas problemáticas
    RunPS1Admin(b + '\\scripts\\diagnostico.ps1',
        '-ParamFile "' + paramFile + '"');
}

function VBS_Limpeza() { RunBatAdmin(GetBase() + '\\scripts\\limpeza.bat'); }

function VBS_Rede(op) { RunPS1Admin(GetBase() + '\\scripts\\rede.ps1', '-Acao ' + op); }

function VBS_Drivers(a) { RunPS1Admin(GetBase() + '\\scripts\\drivers.ps1', '-Acao ' + a); }

function VBS_Instalar(pkg, nm) {
    var b = GetBase();
    try {
        sa().ShellExecute('cmd.exe',
            '/k "' + b + '\\scripts\\instalar.bat" "' + pkg + '" "' + nm + '"',
            '', 'runas', 1);
    } catch(e) { alert('Erro: ' + e.message); }
}

function VBS_WU(a) { RunPS1Admin(GetBase() + '\\scripts\\windows-update.ps1', '-Acao ' + a); }

function VBS_Tool(t) { RunPS1(GetBase() + '\\scripts\\abrir-ferramenta.ps1', '-Ferramenta ' + t); }

function VBS_Admin(t) { RunBatAdmin(GetBase() + '\\scripts\\runas-admin.bat ' + t); }

function VBS_GitHub(a, repo, branch, tok) {
    var args = '-Acao ' + a + ' -Repo "' + repo + '" -Branch "' + branch + '"';
    if (tok) args += ' -Token "' + tok + '"';
    RunPS1Admin(GetBase() + '\\scripts\\atualizar-github.ps1', args);
}

function VBS_BaixarTools() { RunPS1Admin(GetBase() + '\\scripts\\baixar-ferramentas.ps1', ''); }

function VBS_AbrirRelats() { OpenDir(GetBase() + '\\relatorios'); }

function VBS_Pnputil() {
    try { sa().ShellExecute('pnputil.exe', '/scan-devices', '', 'runas', 1); } catch(e) {}
}

function VBS_CleanBrowser() {
    try {
        sa().ShellExecute('cmd.exe',
            '/k powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "Remove-Item -Recurse -Force -EA SilentlyContinue \"$env:LOCALAPPDATA\\Google\\Chrome\\User Data\\Default\\Cache\",\"$env:LOCALAPPDATA\\Microsoft\\Edge\\User Data\\Default\\Cache\"; Write-Host Cache_limpo; Start-Sleep 2"',
            '', 'runas', 1);
    } catch(e) {}
}

function VBS_CleanLogs() {
    try {
        sa().ShellExecute('cmd.exe',
            '/k powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "Get-EventLog -LogName * | ForEach-Object { Clear-EventLog -LogName $_.Log -EA SilentlyContinue }; Write-Host Logs_limpos; Start-Sleep 2"',
            '', 'runas', 1);
    } catch(e) {}
}

// ── Detecção de ambiente ────────────────────────────────
var IS_HTA = false;
try {
    new ActiveXObject('Scripting.FileSystemObject');
    IS_HTA = true;
} catch(e) { IS_HTA = false; }

// Storage (HTA = arquivo INI; Browser = localStorage)
var Store = {
    get: function(k) {
        if (IS_HTA) { try { var v = ReadCfg(k); return v || null; } catch(e) { return null; } }
        else { try { return localStorage.getItem('mf_' + k); } catch(e) { return null; } }
    },
    set: function(k, v) {
        if (IS_HTA) { try { WriteCfg(k, v); } catch(e) {} }
        else { try { localStorage.setItem('mf_' + k, v); } catch(e) {} }
    }
};

var APP = { auth:false, mode:'P', sgs:false, cnt:0, diag:0 };
var authTab = 'P';

// Relógio
function tick() { document.getElementById('clk').innerText = new Date().toTimeString().slice(0,8); }
setInterval(tick, 1000); tick();

// Hash
function hs(s) { var h=0; for(var i=0;i<s.length;i++){ h=((h<<5)-h+s.charCodeAt(i))|0; } return 'mf'+Math.abs(h).toString(36)+s.length.toString(36); }

// Modo online/offline
function checkMode() {
    var on = navigator.onLine;
    var m = document.getElementById('hmode');
    if (on) { m.className='hmode online'; m.innerText='ONLINE'; } else { m.className='hmode offline'; m.innerText='OFFLINE'; }
    var e = document.getElementById('sEnv'); if(e) e.innerText = IS_HTA ? 'HTA' : 'Browser';
    var am = document.getElementById('amode'); if(am) am.innerText = IS_HTA ? '● Modo HTA — execução real de scripts' : '● Modo navegador — demonstração visual';
}
checkMode();
if (window.addEventListener) { window.addEventListener('online', checkMode); window.addEventListener('offline', checkMode); }

// Auth
function setTab(t) {
    authTab = t;
    document.getElementById('tabP').className = 'atab' + (t==='P'?' on':'');
    document.getElementById('tabC').className = 'atab' + (t==='C'?' on':'');
    document.getElementById('frmP').style.display = t==='P' ? 'block' : 'none';
    document.getElementById('frmC').style.display = t==='C' ? 'block' : 'none';
}

function doAuth() {
    var msg = document.getElementById('amsg'); msg.innerText = '';
    if (authTab === 'P') {
        var p = document.getElementById('tpwd').value;
        if (!p) { msg.innerText = 'Digite a senha'; return; }
        var st = Store.get('th'), hv = hs(p);
        if (!st) { if(p.length<6){ msg.innerText='Mínimo 6 caracteres'; return; } Store.set('th',hv); loginOk('P'); }
        else { if(hv===st) loginOk('P'); else msg.innerText='Senha incorreta'; }
    } else {
        var p2 = document.getElementById('cpwd').value;
        if (!p2) { msg.innerText = 'Digite a senha SGS'; return; }
        var st2 = Store.get('ch'), hv2 = hs(p2);
        if (!st2) { if(p2.length<6){ msg.innerText='Mínimo 6 caracteres'; return; } Store.set('ch',hv2); loginOk('C'); }
        else { if(hv2===st2) loginOk('C'); else msg.innerText='Senha incorreta'; }
    }
}

function loginOk(m) {
    APP.auth=true; APP.mode=m; APP.sgs=(m==='C');
    document.getElementById('authOv').style.display='none';
    document.getElementById('hbadge').innerText = m==='C' ? 'ADM · SGS' : 'TÉCNICO';
    document.getElementById('sModo').innerText = m==='C' ? 'Corp SGS' : 'Técnico';
    if (m==='C') { document.getElementById('sgsLbl').innerText='Autenticado: antonio.oliveira.adm@sgs.com'; document.getElementById('sgsDot').className='dot dg'; }
    toast('Acesso autorizado!','ok');
    log('dTerm','ok','Sessão iniciada — modo '+(m==='C'?'CORPORATIVO SGS':'TÉCNICO'));
    log('dTerm','info','Ambiente: '+(IS_HTA?'HTA — scripts reais ativos':'Navegador — modo demonstração'));
    carregarRelats();
}

function logout() {
    if(!window.confirm('Encerrar sessão?'))return;
    APP.auth=false; APP.sgs=false;
    document.getElementById('authOv').style.display='flex';
    document.getElementById('tpwd').value='';
    document.getElementById('cpwd').value='';
    var sp=document.getElementById('sgsPwd'); if(sp) sp.value='';
    var sd=document.getElementById('sgsDot'); if(sd) sd.className='dot da';
    var sl=document.getElementById('sgsLbl'); if(sl) sl.innerText='Não autenticado';
}

function authSGS() {
    var p=document.getElementById('sgsPwd').value; if(!p){toast('Digite a senha','er');return;}
    var st=Store.get('ch'), hv=hs(p);
    if(!st){Store.set('ch',hv);APP.sgs=true;}
    else if(hv===st){APP.sgs=true;}
    else{toast('Senha SGS incorreta','er');log('adminT','err','Falha SGS');return;}
    document.getElementById('sgsLbl').innerText='Autenticado: antonio.oliveira.adm@sgs.com';
    document.getElementById('sgsDot').className='dot dg';
    toast('Autenticado na SGS!','ok'); log('adminT','ok','Sessão SGS ativa');
}

// Navegação
function pg(id) {
    var ps=document.querySelectorAll('.pg'); for(var i=0;i<ps.length;i++) ps[i].className='pg';
    var el=document.getElementById('pg-'+id); if(el) el.className='pg on';
    var ns=document.querySelectorAll('.ni'); for(var i=0;i<ns.length;i++){ var oc=ns[i].getAttribute('onclick')||''; ns[i].className='ni'+(oc.indexOf("'"+id+"'")>=0?' on':''); }
    if(id==='relat') carregarRelats();
    pgHook(id);
}

// Log
function log(tid,type,msg) {
    var t=document.getElementById(tid); if(!t)return;
    var ts=new Date().toTimeString().slice(0,8);
    var cls={ok:'tok',err:'te',warn:'tw',info:'ti',dim:'tdm'}[type]||'ti';
    var ic={ok:'[OK]',err:'[X]',warn:'[!]',info:'[i]',dim:''}[type]||'[>]';
    var ln=document.createElement('div'); ln.className='tl';
    ln.innerHTML='<span class="tcp">['+ts+']</span> <span class="'+cls+'">'+ic+' '+msg+'</span>';
    t.appendChild(ln); t.scrollTop=t.scrollHeight;
}

// Toast
function toast(msg,type) {
    type=type||'inf'; var c=document.getElementById('toasts');
    var t=document.createElement('div'); t.className='toast '+type;
    var ic={ok:'✓',er:'✕',inf:'ℹ'};
    t.innerHTML='<span style="font-weight:700;margin-right:7px;color:'+(type==='ok'?'#00ff88':type==='er'?'#ff1744':'#00e5ff')+'">'+(ic[type]||'•')+'</span>'+msg;
    c.appendChild(t);
    window.setTimeout(function(){t.style.opacity='0'; window.setTimeout(function(){if(t.parentNode)t.parentNode.removeChild(t);},300);},3500);
}

function cnt() { APP.cnt++; document.getElementById('sCnt').innerText=APP.cnt; }

// Diagnóstico
function execDiag() {
    var cli=document.getElementById('dCli').value||'Cliente';
    var ctx=document.getElementById('dCtx').value;
    var obs=document.getElementById('dObs').value||'-';
    var nm=Store.get('nm')||'Antonio Oliveira';
    document.getElementById('dprog').style.display='block';
    APP.diag++; document.getElementById('sDiag').innerText=APP.diag; cnt();
    var steps=[[0,100],[15,800],[30,1600],[50,2400],[65,3200],[78,4000],[90,4800],[100,5600]];
    var msgs=['Iniciando...','SO, usuário, domínio...','CPU, RAM, slots...','SMART dos discos...','GPU, rede, interfaces...','Windows Update...','Lista de programas...','Score calculado — relatório pronto!'];
    steps.forEach(function(s,i){window.setTimeout(function(){document.getElementById('dpb').style.width=s[0]+'%';document.getElementById('dpct').innerText=s[0]+'%';document.getElementById('dstep').innerText=msgs[i];if(s[0]>0)log('diagT','info',msgs[i]);},s[1]);});
    if(IS_HTA){window.setTimeout(function(){VBS_Diag(cli,ctx,obs,nm);},300);window.setTimeout(function(){toast('Diagnóstico iniciado! Veja o PowerShell.','ok');carregarRelats();registrarHistorico('Diagnóstico',cli,'Executado — aguarde relatório');},5800);}
    else{window.setTimeout(function(){toast('Modo browser — abra INDEX.hta para execução real','inf');},5800);}
}

function execAbrirRelats() { if(IS_HTA)VBS_AbrirRelats(); else toast('Abra o Explorer em relatorios\\','inf'); }

// Limpeza
function execLimpeza() {
    cnt(); log('cleanT','info','Executando limpeza.bat como Admin...');
    if(IS_HTA){VBS_Limpeza();document.getElementById('cleanRes').innerHTML='<span style="color:#00ff88">Script em execução — veja a janela CMD</span><br><span style="font-size:11px;color:#4a7a9b">'+new Date().toLocaleString('pt-BR')+'</span>';toast('Limpeza iniciada! Confirme o UAC.','ok');registrarHistorico('Limpeza',window.location.hostname||'PC','Executada');}
    else toast('Abra INDEX.hta','inf');
}
function execCleanBrowser(){cnt();if(IS_HTA){VBS_CleanBrowser();toast('Cache de navegadores limpo!','ok');}else toast('Abra INDEX.hta','inf');}
function execCleanLogs(){cnt();if(IS_HTA){VBS_CleanLogs();toast('Event logs limpos!','ok');}else toast('Abra INDEX.hta','inf');}

// Relatórios
function carregarRelats() {
    var el=document.getElementById('relatList'), nb=document.getElementById('nRelat');
    if(!IS_HTA){el.innerHTML='<span style="color:#4a7a9b">Disponível apenas no HTA.</span>';nb.innerText='—';return;}
    try {
        var lista=ListRelatorios();
        if(!lista||lista.trim()===''){el.innerHTML='<span style="color:#4a7a9b">Nenhum relatório em relatorios\\ ainda.</span>';nb.innerText='0';return;}
        var itens=lista.split('\n').filter(function(x){return x.trim()!=='';});
        nb.innerText=itens.length;
        var html='<table class="tbl"><thead><tr><th>Arquivo</th><th>Data</th><th></th></tr></thead><tbody>';
        itens.forEach(function(item){
            var p=item.split('|'); if(p.length<3)return;
            var nome=p[0],cam=p[1],data=p[2];
            var cor=nome.indexOf('bateria')>=0?'#ffab00':(nome.indexOf('diagnostico')>=0?'#00e5ff':'#8ab4d4');
            html+='<tr><td class="mono" style="color:'+cor+'">'+nome+'</td><td class="mono">'+data+'</td><td style="white-space:nowrap">';
            if(nome.slice(-4)==='.txt') html+='<button class="btn bo" style="font-size:10px;padding:3px 8px;margin-right:4px" onclick="verRelat(\''+cam.replace(/\\/g,'\\\\')+'\')" >👁</button>';
            html+='<button class="btn bo" style="font-size:10px;padding:3px 8px" onclick="abrirArq(\''+cam.replace(/\\/g,'\\\\')+'\')" >📂</button>';
            html+='</td></tr>';
        });
        html+='</tbody></table>';
        el.innerHTML=html;
    }catch(e){el.innerHTML='<span style="color:#ff1744">Erro: '+e.message+'</span>';}
}

function verRelat(cam) {
    if(!IS_HTA)return;
    var c=ReadFile(cam); if(!c){toast('Erro ao ler arquivo','er');return;}
    var rv=document.getElementById('relatViewer'), html='';
    c.split('\n').forEach(function(l){
        var lt=l.trim(), cl='';
        if(lt.indexOf('===')>=0||lt.indexOf('---')>=0) cl='color:#00e5ff;font-weight:bold';
        else if(lt.indexOf('[v]')>=0||lt.indexOf('EXCELENTE')>=0||lt.indexOf('NAO - HARDWARE')>=0) cl='color:#00ff88';
        else if(lt.indexOf('[!]')>=0||lt.indexOf('ATENCAO')>=0||lt.indexOf('SIM - UPGRADE')>=0) cl='color:#ffab00';
        html+='<div class="tl" style="white-space:pre;'+cl+'">'+l.replace(/&/g,'&amp;').replace(/</g,'&lt;')+'</div>';
    });
    rv.innerHTML=html; pg('relat');
}

function abrirArq(cam) { if(!IS_HTA)return; try{var sh=new ActiveXObject('WScript.Shell');sh.Run('"'+cam+'"',1,false);}catch(e){toast('Erro','er');} }

function execSetupDefender(){
    cnt();
    log('dTerm','warn','Executando SETUP-DEFENDER.bat como Admin...');
    if(IS_HTA){
        var b=GetBase();
        try{
            sa().ShellExecute('cmd.exe',
                '/k powershell.exe -NoProfile -ExecutionPolicy Bypass -File "'+b+'\\scripts\\setup-exclusao.ps1"',
                '','runas',1);
            toast('Setup do Defender iniciado! Confirme o UAC.','ok');
        }catch(e){ alert('Execute manualmente: SETUP-DEFENDER.bat (clique direito → Admin)'); }
    } else { toast('Abra INDEX.hta no pendrive','inf'); }
}

