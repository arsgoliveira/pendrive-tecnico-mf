<!-- DIAGNÓSTICO -->
<div class="pg" id="pg-diag">
  <div class="ptit">🔍 <span>Diagnóstico</span> Completo</div>
  <div class="pdesc">diagnostico.ps1 — coleta dados reais + Score A–F + relatório .TXT formato SGS</div>
  <div class="row mb14">
    <div class="col2">
      <div class="card">
        <div class="ct">Dados do Atendimento</div>
        <label class="fl">Nome do Cliente / PC</label>
        <input class="fi" id="dCli" placeholder="Ex: João Silva / NOTEBOOK-01"/>
        <label class="fl">Contexto</label>
        <select class="fi" id="dCtx"><option>SGS</option><option>MicroFast Informática</option><option>Hidromares by SGS</option><option>Outro</option></select>
        <label class="fl">Observações</label>
        <input class="fi" id="dObs" placeholder="Ex: PC lento, tela azul"/>
      </div>
    </div>
    <div class="col2">
      <div class="card">
        <div class="ct">O que é coletado</div>
        <div style="font-size:15px;color:#8ab4d4;line-height:2.2">
          ✅ SO, versão, build, último boot<br>
          ✅ Usuário, domínio, perfil<br>
          ✅ CPU: modelo, núcleos, threads<br>
          ✅ RAM: total, uso, slots, velocidade<br>
          ✅ Disco: SMART nativo, espaço, SSD/HDD<br>
          ✅ GPU: modelo, driver, VRAM<br>
          ✅ Rede: interfaces, IP, gateway, ping<br>
          ✅ Windows Update pendentes<br>
          ✅ Programas instalados (lista completa)<br>
          ✅ Bateria + powercfg/batteryreport<br>
          ✅ <strong style="color:#00e5ff">Score upgrade A–F automático</strong>
        </div>
      </div>
    </div>
  </div>
  <button class="btn bp" onclick="execDiag()">▶ EXECUTAR DIAGNÓSTICO</button>
  <button class="btn bo" onclick="execAbrirRelats()">📁 Pasta Relatórios</button>
  <button class="btn bo" onclick="pg('relat')">📋 Ver Relatórios</button>
  <div id="dprog" style="display:none;margin:.5rem 0 0">
    <div style="display:-ms-flexbox;display:flex;-ms-flex-pack:justify;justify-content:space-between;font-size:11px;color:#4a7a9b;margin-bottom:3px">
      <span id="dstep">Aguardando...</span><span id="dpct">0%</span>
    </div>
    <div class="pw"><div class="pb" id="dpb" style="width:0%"></div></div>
  </div>
  <div class="term" id="diagT"><div class="tl"><span class="tdm">Aguardando diagnóstico...</span></div></div>
</div>

<!-- LIMPEZA -->
<div class="pg" id="pg-clean">
  <div class="ptit">🧹 Limpeza <span>Automática</span></div>
  <div class="pdesc">limpeza.bat executado como Administrador — ação real no sistema</div>
  <div class="row mb14">
    <div class="col2">
      <div class="card">
        <div class="ct">limpeza.bat remove</div>
        <div style="font-size:15px;color:#8ab4d4;line-height:2.2">
          ✅ %TEMP% — pasta temp do usuário<br>
          ✅ C:\Windows\Temp — temp do sistema<br>
          ✅ C:\Windows\Prefetch<br>
          ✅ Lixeira (todos os usuários)<br>
          ✅ Cache Windows Update<br>
          ✅ Cache DNS (ipconfig /flushdns)
        </div>
        <br/>
        <button class="btn bp" style="width:100%" onclick="execLimpeza()">🧹 EXECUTAR LIMPEZA REAL</button>
      </div>
    </div>
    <div class="col2">
      <div class="card">
        <div class="ct">Limpeza Extra</div>
        <button class="tb" onclick="execCleanBrowser()"><span class="tik" style="background:rgba(0,229,255,.08)">🌐</span><span class="tinfo"><span class="tn">Cache de Navegadores</span><br><span class="td">Chrome, Edge, Firefox</span></span></button>
        <button class="tb" onclick="execCleanLogs()"><span class="tik" style="background:rgba(0,229,255,.08)">📋</span><span class="tinfo"><span class="tn">Limpar Event Logs</span><br><span class="td">Logs de eventos antigos</span></span></button>
        <div id="cleanRes" style="font-size:14px;color:#4a7a9b;margin-top:.875rem">Nenhuma limpeza executada.</div>
      </div>
    </div>
  </div>
  <div class="term" id="cleanT"><div class="tl"><span class="tdm">Aguardando limpeza...</span></div></div>
</div>

