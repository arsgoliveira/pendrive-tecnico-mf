// Guias
var guiaDB={
    diag:'<div class="gstep"><span class="gsn">1</span><span class="gst">Preencha os dados do atendimento</span><div class="gsd">Informe nome do cliente, contexto (SGS/MicroFast) e observações. Aparecem no cabeçalho do relatório.</div></div><div class="gstep"><span class="gsn">2</span><span class="gst">Clique em Executar Diagnóstico</span><div class="gsd">O Windows pedirá UAC. Clique em Sim. Uma janela PowerShell azul coletará os dados em tempo real.</div></div><div class="gstep"><span class="gsn">3</span><span class="gst">Aguarde 30s a 2 minutos</span><div class="gsd">Coleta: SO, build, usuário/domínio, CPU, RAM (slots/velocidade), disco (SMART), GPU, rede, Windows Update e programas instalados.</div></div><div class="gstep"><span class="gsn">4</span><span class="gst">Relatório abre automaticamente</span><div class="gsd">Bloco de Notas abre com .TXT em relatorios\\. Em notebooks, pergunta se quer relatório de bateria (powercfg /batteryreport).</div></div><div class="gstep"><span class="gsn">5</span><span class="gst">Score de Upgrade A–F</span><div class="gsd">Score 0–75 baseado em RAM, tipo de disco (SSD/HDD) e geração do CPU. Alertas críticos em laranja.</div><span class="gsc">Nota A (70+): excelente | B: bom | C: adequado | D/F: upgrade necessário</span></div>',
    clean:'<div class="gstep"><span class="gsn">1</span><span class="gst">Clique em Executar Limpeza Real</span><div class="gsd">O Windows pedirá UAC. Clique em Sim. CMD preta mostra cada etapa.</div></div><div class="gstep"><span class="gsn">2</span><span class="gst">O que é removido</span><div class="gsd">%TEMP%, C:\\Windows\\Temp, Prefetch, Lixeira, cache do Windows Update e cache DNS.</div><span class="gsc">Liberação típica: 500MB a 5GB</span></div><div class="gstep"><span class="gsn">3</span><span class="gst">Limpeza extra de navegadores</span><div class="gsd">Use os botões extras para cache do Chrome, Edge e Firefox.</div></div><div class="gstep"><span class="gsn">4</span><span class="gst">Quando usar</span><div class="gsd">Execute sempre antes de diagnósticos para garantir leituras precisas de espaço. Passo 1 de qualquer atendimento.</div></div>',
    rede:'<div class="gstep"><span class="gsn">1</span><span class="gst">Menu interativo no PowerShell</span><div class="gsd">Qualquer botão de rede abre uma janela PS com menu numerado. Digite o número e Enter.</div></div><div class="gstep"><span class="gsn">2</span><span class="gst">Ping Avançado [1]</span><div class="gsd">10 pings com: enviados/recebidos, perda%, mín/máx/média. Perda > 10% = instabilidade.</div></div><div class="gstep"><span class="gsn">3</span><span class="gst">Traceroute [2]</span><div class="gsd">Mostra cada roteador (hop) até o destino. Identifica onde a conexão está lenta.</div></div><div class="gstep"><span class="gsn">4</span><span class="gst">Renovar IP [9]</span><div class="gsd">ipconfig /release + /renew. Resolve IP 169.254.x.x (APIPA), conflito de IP e sem conectividade.</div></div>',
    hwinfo:'<div class="gstep"><span class="gsn">1</span><span class="gst">Baixe a versão Portable</span><div class="gsd">hwinfo.com → baixe o pacote Portable 64-bit → extraia para tools\\HWiNFO64\\HWiNFO64.exe no pendrive.</div></div><div class="gstep"><span class="gsn">2</span><span class="gst">Abra pelo painel</span><div class="gsd">Ferramentas → HWiNFO64. Se ausente, oferece instalar via winget.</div></div><div class="gstep"><span class="gsn">3</span><span class="gst">Temperaturas críticas</span><div class="gsd">CPU Package > 90°C = superaquecimento. GPU > 90°C = problema de ventilação. NVMe > 70°C = alerta.</div></div><div class="gstep"><span class="gsn">4</span><span class="gst">Logging de sensores</span><div class="gsd">Botão direito → Start Logging. Grava CSV de temperaturas. Ideal para diagnosticar throttling.</div></div>',
    cdisk:'<div class="gstep"><span class="gsn">1</span><span class="gst">CrystalDiskInfo — status SMART</span><div class="gsd">Sem instalação. Mostra saúde de cada disco físico.</div></div><div class="gstep"><span class="gsn">2</span><span class="gst">Interpretando status</span><div class="gsd">Bom (azul): saudável. Atenção (amarelo): monitore. Ruim (vermelho): falha iminente — BACKUP URGENTE.</div></div><div class="gstep"><span class="gsn">3</span><span class="gst">Atributos críticos</span><div class="gsd">05 Reallocated Sectors, C5 Pending Sectors, C6 Uncorrectable. Qualquer valor ≠ 0 = problema sério.</div></div><div class="gstep"><span class="gsn">4</span><span class="gst">CrystalDiskMark — velocidade</span><div class="gsd">Clique em All. SSD NVMe Gen4 > 5000 MB/s. SSD SATA > 400 MB/s. HDD > 100 MB/s.</div></div>',
    malware:'<div class="gstep"><span class="gsn">1</span><span class="gst">Execute RKill primeiro</span><div class="gsd">Mata processos de malware ativos. Aguarde fechar sozinho.</div></div><div class="gstep"><span class="gsn">2</span><span class="gst">AdwCleaner</span><div class="gsd">Scan Now → Quarantine. Remove adware, toolbars e PUPs.</div></div><div class="gstep"><span class="gsn">3</span><span class="gst">Malwarebytes</span><div class="gsd">Scan → Threat Scan. 10–30 min. Remove malware, ransomware e rootkits.</div></div><div class="gstep"><span class="gsn">4</span><span class="gst">Autoruns (Segurança)</span><div class="gsd">Options → Scan Options → Check VirusTotal. Entradas suspeitas em vermelho.</div></div><div class="gstep"><span class="gsn">5</span><span class="gst">Reinicie e confirme</span><div class="gsd">Execute novo diagnóstico para confirmar sistema limpo.</div></div>',
    drivers:'<div class="gstep"><span class="gsn">1</span><span class="gst">Detectar Hardware primeiro</span><div class="gsd">Identifica fabricante real via WMI e abre site correto: Dell, Lenovo, HP, Asus, Acer.</div></div><div class="gstep"><span class="gsn">2</span><span class="gst">Driver de Vídeo específico</span><div class="gsd">NVIDIA → GeForce.com. AMD → AMD.com/support. Intel → Intel Driver Assistant.</div></div><div class="gstep"><span class="gsn">3</span><span class="gst">pnputil para "!" no Gerenciador</span><div class="gsd">Força Windows reescanear todos os dispositivos Plug and Play.</div></div><div class="gstep"><span class="gsn">4</span><span class="gst">Evite ferramentas de terceiros</span><div class="gsd">Driver Booster, Driver Easy = drivers não homologados. Use pnputil + Windows Update + site do fabricante.</div></div>',
    winupd:'<div class="gstep"><span class="gsn">1</span><span class="gst">Verificar antes de instalar</span><div class="gsd">Liste as pendências para mostrar ao cliente antes de prosseguir.</div></div><div class="gstep"><span class="gsn">2</span><span class="gst">Corporativo SGS: use Só Segurança</span><div class="gsd">Evita atualizações que quebram configurações gerenciadas pelo Intune.</div></div><div class="gstep"><span class="gsn">3</span><span class="gst">PSWindowsUpdate automático</span><div class="gsd">Instalado automaticamente na primeira execução. Requer internet.</div></div><div class="gstep"><span class="gsn">4</span><span class="gst">Defender independentemente</span><div class="gsd">Rápido (< 1 min), não requer reinício.</div></div>'
};
function guia(id) { var n={diag:'Diagnóstico',clean:'Limpeza',rede:'Rede',hwinfo:'HWiNFO64',cdisk:'CrystalDisk',malware:'Malware',drivers:'Drivers',winupd:'Win Update'}; if(guiaDB[id]) document.getElementById('guiaBox').innerHTML='<div class="stit">📖 '+n[id]+'</div>'+guiaDB[id]; }

// ── V4.0 — Desinstalar ───────────────────────────────────
function execDesinstalar() {
    var nm = document.getElementById('desinstNm').value;
    if (!nm) { toast('Informe o nome do programa','er'); return; }
    cnt(); log('desinstT','info','Buscando: '+nm);
    if (IS_HTA) {
        RunPS1Admin(GetBase()+'\\scripts\\desinstalar.ps1', '-NomePrograma "'+san(nm)+'" -Acao remover');
        toast('Desinstalador iniciado!','inf');
        registrarHistorico('Desinstalar', nm, 'Iniciado');
    } else toast('Abra INDEX.hta','inf');
}
function execDesinstalarMenu() {
    cnt(); log('desinstT','info','Abrindo lista de programas...');
    if (IS_HTA) {
        RunPS1Admin(GetBase()+'\\scripts\\desinstalar.ps1', '-Acao listar');
        toast('Lista aberta no PowerShell','inf');
    } else toast('Abra INDEX.hta','inf');
}

// ── V4.0 — Histórico ─────────────────────────────────────
var _sesAcoes = 0;
function registrarHistorico(tipo, cliente, resultado) {
    _sesAcoes++;
    var el = document.getElementById('hSes'); if(el) el.innerText = _sesAcoes;
    if (!IS_HTA) return;
    try {
        var nm = Store.get('nm') || 'Antonio Oliveira';
        RunPS1(GetBase()+'\\scripts\\historico.ps1',
            '-Acao registrar -TipoAcao "'+san(tipo)+'" -Cliente "'+san(cliente)+'" -Resultado "'+san(resultado)+'" -Tecnico "'+san(nm)+'"');
    } catch(e) {}
}
function carregarHistorico() {
    var el = document.getElementById('histTable');
    var tot = document.getElementById('hTot');
    var ult = document.getElementById('hUlt');
    var hpc = document.getElementById('hPc');
    if (!IS_HTA) { el.innerHTML='<span style="color:#4a7a9b">Disponível apenas no HTA.</span>'; return; }
    try {
        var csvPath = GetBase() + '\\relatorios\\historico.csv';
        var c = ReadFile(csvPath);
        if (!c || c.trim() === '') { el.innerHTML='<span style="color:#4a7a9b">Nenhum atendimento registrado ainda.</span>'; return; }
        var linhas = c.split('\n').filter(function(l){ return l.trim() !== ''; });
        var dados = linhas.slice(1); // pula header
        if (tot) tot.innerText = dados.length;
        // Últimos registros
        var ultDados = dados.slice(-1)[0];
        if (ultDados && ult) {
            var p = ultDados.replace(/"/g,'').split(',');
            if (p.length >= 4) { ult.innerText = (p[0]||'—').trim(); hpc.innerText = (p[4]||'—').trim(); }
        }
        // Tabela
        var html = '<table class="tbl"><thead><tr><th>Data</th><th>Hora</th><th>Ação</th><th>Cliente</th><th>PC</th><th>Resultado</th></tr></thead><tbody>';
        dados.slice(-50).reverse().forEach(function(ln) {
            var c2 = ln.replace(/"/g,'').split(',');
            if (c2.length < 6) return;
            var cor = c2[5] && c2[5].indexOf('Nota A') >= 0 ? '#00c853' :
                      c2[5] && c2[5].indexOf('Nota F') >= 0 ? '#ff1744' : '#8ab4d4';
            html += '<tr><td class="mono">'+c2[0]+'</td><td class="mono">'+c2[1]+'</td>' +
                    '<td>'+c2[2]+'</td><td>'+c2[3]+'</td><td class="mono">'+c2[4]+'</td>' +
                    '<td style="color:'+cor+'">'+c2[5]+'</td></tr>';
        });
        html += '</tbody></table>';
        el.innerHTML = html;
    } catch(e) { el.innerHTML='<span style="color:#ff1744">Erro: '+e.message+'</span>'; }
}
function execHistoricoPS() {
    cnt();
    if (IS_HTA) { RunPS1Admin(GetBase()+'\\scripts\\historico.ps1','-Acao listar'); toast('Histórico aberto!','inf'); }
    else toast('Abra INDEX.hta','inf');
}
function execExportarHistorico() {
    cnt();
    if (IS_HTA) { RunPS1(GetBase()+'\\scripts\\historico.ps1','-Acao exportar'); toast('Exportando CSV...','ok'); }
    else toast('Abra INDEX.hta','inf');
}

// ── V4.0 — Reset senha ───────────────────────────────────
function execResetSenha() {
    if (!window.confirm('Isso vai apagar as senhas salvas.\nVocê precisará definir novas senhas no próximo acesso.\n\nConfirmar?')) return;
    cnt();
    if (IS_HTA) {
        RunPS1Admin(GetBase()+'\\scripts\\reset-senha.ps1','');
        toast('Script de reset aberto!','inf');
    } else {
        // No browser: limpa o localStorage
        Store.set('th',''); Store.set('ch','');
        toast('Senhas removidas — recarregue para definir novas','ok');
    }
}

// ── V4.0 — Hardware ao vivo via WMI ──────────────────────
var _hwInterval = null;
function hwStart() {
    if (!IS_HTA) {
        // Modo browser: mostra valores simulados
        document.getElementById('hwCpu').innerText = 'N/A';
        document.getElementById('hwRam').innerText = 'N/A';
        document.getElementById('hwDisk').innerText = 'N/A';
        document.getElementById('hwBat').innerText = 'N/A';
        document.getElementById('hwCpuDetail').innerHTML = '<span style="color:#4a7a9b">WMI disponível apenas no HTA</span>';
        document.getElementById('hwRamDetail').innerHTML = '<span style="color:#4a7a9b">WMI disponível apenas no HTA</span>';
        document.getElementById('hwDiskDetail').innerHTML = '<span style="color:#4a7a9b">WMI disponível apenas no HTA</span>';
        document.getElementById('hwSysDetail').innerHTML = '<span style="color:#4a7a9b">WMI disponível apenas no HTA</span>';
        return;
    }
    if (_hwInterval) return;
    hwRead();
    _hwInterval = setInterval(hwRead, 3000);
}
function hwStop() { if (_hwInterval) { clearInterval(_hwInterval); _hwInterval = null; } }
function hwRead() {
    try {
        var wmi = GetObject('winmgmts:{impersonationLevel=impersonate}!//./root/cimv2');
        // CPU
        var cpuQ = new Enumerator(wmi.ExecQuery('SELECT Name,NumberOfCores,NumberOfLogicalProcessors,MaxClockSpeed,LoadPercentage FROM Win32_Processor'));
        if (!cpuQ.atEnd()) {
            var cpu = cpuQ.item();
            var load = cpu.LoadPercentage || 0;
            document.getElementById('hwCpu').innerText = load + '%';
            document.getElementById('hwCpuPct').innerText = load + '%';
            document.getElementById('hwCpuBar').style.width = load + '%';
            document.getElementById('hwCpuBar').style.background = load > 80 ? '#ff1744' : load > 50 ? '#ffab00' : '#00e5ff';
            document.getElementById('hwCpuDetail').innerHTML =
                '<div class="row"><span class="lbl">Modelo</span><span class="val" style="font-size:11px">' + (cpu.Name||'').trim() + '</span></div>' +
                '<div class="row"><span class="lbl">Núcleos</span><span class="val">' + cpu.NumberOfCores + ' / ' + cpu.NumberOfLogicalProcessors + ' threads</span></div>' +
                '<div class="row"><span class="lbl">Clock</span><span class="val">' + cpu.MaxClockSpeed + ' MHz</span></div>';
        }
        // RAM
        var osQ = new Enumerator(wmi.ExecQuery('SELECT TotalVisibleMemorySize,FreePhysicalMemory FROM Win32_OperatingSystem'));
        if (!osQ.atEnd()) {
            var osInfo = osQ.item();
            var total = Math.round(osInfo.TotalVisibleMemorySize / 1048576 * 10) / 10;
            var free  = Math.round(osInfo.FreePhysicalMemory  / 1048576 * 10) / 10;
            var used  = Math.round((total - free) * 10) / 10;
            var pct   = Math.round(used / total * 100);
            document.getElementById('hwRam').innerText = used + ' GB';
            document.getElementById('hwRamPct').innerText = pct + '%';
            document.getElementById('hwRamBar').style.width = pct + '%';
            document.getElementById('hwRamBar').style.background = pct > 85 ? '#ff1744' : pct > 65 ? '#ffab00' : '#00c853';
            document.getElementById('hwRamDetail').innerHTML =
                '<div class="row"><span class="lbl">Total</span><span class="val">' + total + ' GB</span></div>' +
                '<div class="row"><span class="lbl">Em uso</span><span class="val">' + used + ' GB (' + pct + '%)</span></div>' +
                '<div class="row"><span class="lbl">Disponível</span><span class="val">' + free + ' GB</span></div>';
        }
        // Discos
        var dskQ = new Enumerator(wmi.ExecQuery("SELECT DeviceID,Size,FreeSpace FROM Win32_LogicalDisk WHERE DriveType=3"));
        var dskHtml = ''; var diskFreeC = '—';
        for (; !dskQ.atEnd(); dskQ.moveNext()) {
            var d = dskQ.item();
            var tot = Math.round(d.Size/1073741824*10)/10;
            var liv = Math.round(d.FreeSpace/1073741824*10)/10;
            var pctD = Math.round((tot-liv)/tot*100);
            var cor  = pctD > 85 ? '#ff1744' : pctD > 70 ? '#ffab00' : '#00c853';
            dskHtml += '<div class="row"><span class="lbl">' + d.DeviceID + '</span>' +
                       '<span class="val" style="color:'+cor+'">'+liv+' GB livre / '+tot+' GB ('+pctD+'%)</span></div>';
            if (d.DeviceID === 'C:') diskFreeC = liv + ' GB';
        }
        document.getElementById('hwDisk').innerText = diskFreeC;
        document.getElementById('hwDiskDetail').innerHTML = dskHtml || '<span style="color:#4a7a9b">Sem dados</span>';
        // Sistema
        var compQ = new Enumerator(wmi.ExecQuery('SELECT CSName,Domain,UserName,TotalPhysicalMemory FROM Win32_ComputerSystem'));
        var sysHtml = '';
        if (!compQ.atEnd()) {
            var comp = compQ.item();
            sysHtml += '<div class="row"><span class="lbl">PC</span><span class="val">'+(comp.CSName||'')+'</span></div>' +
                       '<div class="row"><span class="lbl">Domínio</span><span class="val">'+(comp.Domain||'')+'</span></div>' +
                       '<div class="row"><span class="lbl">Usuário</span><span class="val">'+String(comp.UserName||'').split('\\').pop()+'</span></div>';
        }
        // Bateria
        var batQ = new Enumerator(wmi.ExecQuery('SELECT EstimatedChargeRemaining,BatteryStatus FROM Win32_Battery'));
        if (!batQ.atEnd()) {
            var bat = batQ.item();
            var carga = bat.EstimatedChargeRemaining || 0;
            var batSt = bat.BatteryStatus;
            var batCor = carga < 20 ? '#ff1744' : carga < 40 ? '#ffab00' : '#00c853';
            document.getElementById('hwBat').innerHTML = '<span style="color:'+batCor+'">' + carga + '%</span>';
            sysHtml += '<div class="row"><span class="lbl">Bateria</span><span class="val" style="color:'+batCor+'">'+carga+'% '+(batSt===2||batSt===6?'⚡':'')+'</span></div>';
        } else {
            document.getElementById('hwBat').innerText = 'N/A';
        }
        document.getElementById('hwSysDetail').innerHTML = sysHtml || '<span style="color:#4a7a9b">Sem dados</span>';
    } catch(e) {
        document.getElementById('hwCpuDetail').innerHTML = '<span style="color:#ff1744">Erro WMI: '+e.message+'</span>';
        hwStop();
    }
}

// ── Intercepta pg() para controlar Hardware live ─────────
// NOTA: IE não permite pg = function(){} após function pg(){} - usar flag interna
var _hwActivePage = '';
function pgHook(id) {
    if (_hwActivePage === 'hardware' && id !== 'hardware') { hwStop(); }
    _hwActivePage = id;
    if (id === 'hardware') { hwStart(); }
    if (id === 'historico') { carregarHistorico(); }
}

// Config
function saveCfg(){Store.set('nm',document.getElementById('cfgNm').value);Store.set('emp',document.getElementById('cfgEmp').value);Store.set('fone',document.getElementById('cfgFone').value);toast('Config salva!','ok');}
function saveCreds(){
    var p1=document.getElementById('np1').value,p2=document.getElementById('np2').value,ps=document.getElementById('nps').value,m=document.getElementById('cfgMsg');
    if(p1){if(p1.length<6){m.innerText='Mín 6 chars';m.style.color='#ff1744';return;}if(p1!==p2){m.innerText='Senhas diferentes';m.style.color='#ff1744';return;}Store.set('th',hs(p1));}
    if(ps) Store.set('ch',hs(ps));
    m.innerText='✓ Credenciais atualizadas'; m.style.color='#00ff88'; toast('Senhas salvas!','ok');
}

// Init
(function(){
    var nm=Store.get('nm'); if(nm) document.getElementById('cfgNm').value=nm;
    var emp=Store.get('emp'); if(emp) document.getElementById('cfgEmp').value=emp;    var fn=Store.get('fone'); if(fn) document.getElementById('cfgFone').value=fn;
    var repo=Store.get('ghrepo'); if(repo) document.getElementById('ghRepo').value=repo;
    if(Store.get('th')) document.getElementById('anote').innerText='Credenciais configuradas. Digite sua senha.';
    checkMode();
    // Verifica versão remota no GitHub em background
    if(navigator.onLine){
        try{
            var x=new XMLHttpRequest();
            x.open('GET','https://raw.githubusercontent.com/arsgoliveira/pendrive-tecnico-mf/main/config/versao.txt',true);
            x.onload=function(){
                if(x.status===200){
                    var remote=x.responseText.trim();
                    var local='3.0.2';
                    try{var vf=ReadFile(GetBase()+'\\config\\versao.txt');if(vf)local=vf.trim();}catch(e){}
                    if(remote&&remote!==local){
                        var vb=document.getElementById('ghVer');
                        if(vb){vb.innerText='v'+remote+' disponível!';vb.style.color='#ffab00';}
                        log('dTerm','warn','Atualização disponível: v'+local+' → v'+remote+' (Painel → Atualizar)');
                    }
                }
            };
            x.send();
        }catch(e){}
    }
})();
</script>
</body>
</html>
