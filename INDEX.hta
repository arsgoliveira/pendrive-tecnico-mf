function execGitCheck(){cnt();log('gitT','info','Verificando GitHub...');if(IS_HTA){VBS_GitHub('verificar',document.getElementById('ghRepo').value,document.getElementById('ghBranch').value,document.getElementById('ghTok').value);toast('Verificação iniciada!','inf');}else toast('Abra INDEX.hta','inf');}
